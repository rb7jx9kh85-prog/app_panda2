rules_version = '2';

// ─────────────────────────────────────────────────────────────
// Règles de sécurité Firestore — Le Panda
// ─────────────────────────────────────────────────────────────
// Modèle :
//   restaurants/{restaurantId}
//     ├── live/current      → lecture PUBLIQUE (site vitrine en temps réel)
//     │                        écriture : authentifiés
//     └── menus/{menuId}    → lecture/écriture : authentifiés uniquement
//
service cloud.firestore {
  match /databases/{database}/documents {

    match /restaurants/{restaurantId} {

      // Document racine du restaurant : réservé aux utilisateurs authentifiés.
      allow read, write: if request.auth != null;

      // Document(s) "live" (dont current) : lecture PUBLIQUE car le site
      // vitrine lepanda.vercel.app les écoute en onSnapshot sans être connecté.
      // L'écriture reste réservée aux utilisateurs authentifiés (le gérant).
      match /live/{docId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      // Archives des menus publiés : lecture et écriture authentifiées.
      match /menus/{menuId} {
        allow read, write: if request.auth != null;
      }

      // Menus planifiés (brouillons pour planification à l'avance) :
      // lecture et écriture : authentifiés uniquement
      match /menus_planifies/{planId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
