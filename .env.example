# ─────────────────────────────────────────────────────────────
# Le Panda — Administration · Variables d'environnement
# ─────────────────────────────────────────────────────────────
# Copiez ce fichier en `.env.local` puis remplissez les valeurs.
# `.env.local` est ignoré par git (voir .gitignore) — ne jamais committer de secrets.

# Firebase (console.firebase.google.com → Paramètres du projet → Vos applications)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# OpenAI (platform.openai.com → API keys)
# ATTENTION : préfixe VITE_ ⇒ clé exposée côté client (voir commentaire dans src/services/openai.js)
VITE_OPENAI_API_KEY=

# Identifiant fixe du restaurant dans Firestore
VITE_PANDA_RESTAURANT_ID=panda_leytron

# Web3Forms — pour envoyer les demandes de modification du site vitrine
# Récupérez la clé d'accès sur https://web3forms.com
# ⚠️  Pour la sécurité, idéalement cette clé devrait être sur un backend serverless
VITE_WEB3FORMS_KEY=

# Email de destination pour les demandes de modification (configurable)
VITE_CONTACT_EMAIL=noevouillamoz3@gmail.com
